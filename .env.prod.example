# ============================================================
# QuantPilot 生产环境变量模板（Phase 10 §8.2）
# 用法：cp .env.prod.example .env.prod && 填入实际值
#      docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# === PostgreSQL ===
POSTGRES_DB=quantpilot
POSTGRES_USER=quantpilot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://quantpilot:CHANGE_ME_STRONG_PASSWORD@db:5432/quantpilot

# === Redis ===
REDIS_PASSWORD=                                    # 不需要密码时留空
REDIS_URL=redis://redis:6379/0                     # 有密码：redis://:PASSWORD@redis:6379/0

# === JWT 认证（单管理员）===
ADMIN_USERNAME=admin
# 生成哈希：docker run --rm python:3.12-slim python -c "import bcrypt;print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
# 含 $ 的值用单引号包裹
ADMIN_PASSWORD_HASH='$2b$12$REPLACE_WITH_YOUR_BCRYPT_HASH'
# 生成密钥：openssl rand -hex 64
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === 数据源（Tushare Pro）===
# 积分 ≥ 2000 才能使用 daily_basic 等接口；留空则数据 API 返回 503
TUSHARE_TOKEN=

# === 微信推送（Phase 10）===
# 留空时自动降级为仅站内信；SDD §13.1 V1.0 可延后至服务号审核通过再启用
WXPUSHER_APP_TOKEN=
WXPUSHER_UID=

# === 应用 ===
CORS_ORIGINS=["https://your-domain.com","http://localhost"]
HTTP_PORT=80
LOG_LEVEL=INFO

# === 回测护栏（2026-06-15）===
# 单次回测的最长日历跨度（天）。0 = 不限制（本地大内存机）。
# 生产 2GB 机长区间回测（daily_quotes 全量 pivot）会 OOM 拖垮整机——已实测
# 1 年回测把可用内存压到 54M（OOM 边缘）。90 天 ≈ 1 个季度 ≈ 1 年的 1/4，
# 峰值内存约 250M、留 ~75% 余量扛每日 17:30 pipeline 尖峰。超限请求直接 422 拒绝，
# 提示用户在本地运行（scripts/run_backtest_local.py，结果经 /backtest/import 回流）。
BACKTEST_MAX_WINDOW_DAYS=90
