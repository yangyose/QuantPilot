# ============================================================
# QuantPilot 环境变量模板
# 使用方法：cp .env.example .env，然后填入实际值
# ============================================================

# === 数据库 ===
DB_USER=quantpilot
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/quantpilot

# === Redis ===
REDIS_PASSWORD=changeme
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# === JWT 认证 ===
# ADMIN_USERNAME / ADMIN_PASSWORD_HASH（V1.5-G 起）仅供 alembic 0018 迁移种子首用户
# 消费，应用运行时不再读取；0018 跑过后可移除（留空则 0018 跳过种子）。
ADMIN_USERNAME=admin
# 生成密码哈希：python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
# 生成密钥：openssl rand -hex 64
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === 数据源（Phase 2 启用）===
TUSHARE_TOKEN=

# === 微信通知（Phase 10 启用）===
WXPUSHER_TOKEN=

# === 应用 ===
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
